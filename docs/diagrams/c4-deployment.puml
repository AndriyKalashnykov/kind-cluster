@startuml c4-deployment
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.13.0/C4_Deployment.puml

' Modern flat styling: no shadows, sharper corners, clean sans-serif, modern palette.
skinparam backgroundColor #FAFAFA
skinparam shadowing false
skinparam roundCorner 4
skinparam defaultFontName "Inter, Helvetica, Arial, sans-serif"
skinparam defaultFontSize 13
skinparam ArrowColor #37474F
skinparam ArrowThickness 1.2
skinparam rectangleBorderThickness 1.3

UpdateElementStyle("person",        $fontColor="#FFFFFF", $bgColor="#0F766E", $borderColor="#134E4A")
UpdateElementStyle("container",     $fontColor="#FFFFFF", $bgColor="#2563EB", $borderColor="#1E3A8A")
UpdateElementStyle("container_db",  $fontColor="#FFFFFF", $bgColor="#7C3AED", $borderColor="#4C1D95")
UpdateElementStyle("node",          $fontColor="#1E293B", $bgColor="#F1F5F9", $borderColor="#94A3B8")
UpdateBoundaryStyle($bgColor="#F1F5F9", $borderColor="#94A3B8", $fontColor="#1E293B")

title Deployment View — kind-cluster

Person(dev, "Developer", "Workstation shell")

Deployment_Node(host, "Host or Multipass VM", "Linux / macOS / Windows + Docker") {
  Deployment_Node(net, "Docker network: kind", "172.18.0.0/16 IPv4 bridge") {
    Deployment_Node(cp, "kind-control-plane", "kindest/node container") {
      Deployment_Node(kube, "kube-system + traefik + headlamp", "namespaces") {
        Container(api, "kube-apiserver, etcd, scheduler, controller-manager", "control-plane components")
        Container(ingress, "traefik controller", "Helm release v3 (40.x); pinned to control-plane via nodeSelector ingress-ready=true")
        Container(metrics, "metrics-server", "manifest")
        Container(dash, "headlamp", "Helm release 0.42.x; ClusterIP :80")
      }
    }
    Deployment_Node(worker, "kind-worker", "kindest/node container") {
      Deployment_Node(workload_ns, "default + nfs-server + monitoring", "namespaces") {
        Container(apps, "Demo workloads", "httpd, hello-app, golang-web, http-echo")
        ContainerDb(nfs, "nfs-server pod", "Pod with emptyDir backing /exports")
        Container(prom, "kube-prometheus-stack", "Prometheus + Grafana + Alertmanager")
      }
    }
    Container(cpk, "cloud-provider-kind", "Host docker container; watches Service: LoadBalancer; allocates IPs from kind subnet")
    Container(cpk_sidecars, "kindccm-<hash>", "Per-Service Envoy sidecar; routes LB IP -> backend pods")

    Deployment_Node(gwapi, "Gateway API controllers (opt-in; not in install-all)", "experimental-channel CRDs v1.5.1, cluster-scoped") {
      Container(gwistio, "Istio", "istiod 1.30.1 in istio-system; Gateway gatewayClassName=istio auto-provisions Envoy Deployment+Service 'istio-istio' (type=LoadBalancer) in default")
      Container(gwngf, "NGINX Gateway Fabric", "control plane 2.6.3 in nginx-gateway; Gateway gatewayClassName=nginx auto-provisions nginx Deployment+Service 'ngf-nginx' (type=LoadBalancer) in default")
      Container(gwcontour, "Project Contour", "provisioner v1.33.5 in projectcontour; Gateway gatewayClassName=contour provisions Envoy DaemonSet+Service 'envoy-contour' (type=LoadBalancer) in default")
      Container(gwenvoy, "Envoy Gateway", "CNCF v1.8.1 in envoy-gateway-system; Gateway gatewayClassName=envoy auto-provisions an Envoy Deployment+Service (generated name) type=LoadBalancer in envoy-gateway-system")
      Container(gwkgateway, "kgateway", "CNCF v2.3.3 (ex-Gloo) in kgateway-system; Gateway gatewayClassName=kgateway auto-provisions Envoy Deployment+Service 'kgw' (type=LoadBalancer) in default")
      Container(gwkong, "Kong (KIC)", "umbrella chart 0.24.0 (DB-less) in kong; unmanaged GatewayClass=kong binds to the single kong proxy Service (type=LoadBalancer); also serves classic Ingress")
    }

    Deployment_Node(ingalt, "Classic Ingress alternatives (opt-in; not in install-all)") {
      Container(inghaproxy, "HAProxy", "haproxytech chart 1.52.0 in haproxy-controller; ingressClassName=haproxy; Service type=LoadBalancer")
      Container(ingnginx, "NGINX Inc.", "F5 OSS chart 2.6.0 in nginx-ingress; ingressClassName=nginx; Service type=LoadBalancer")
    }
  }
}

System_Ext(charts, "Helm chart repos", "traefik, kube-prometheus, headlamp, csi-driver-nfs")
System_Ext(registries, "Container registries", "Docker Hub, GHCR, k8s.gcr.io")

Rel(dev, ingress, "HTTP via Host: *.localdev.me", "127.0.0.1:80 hostPort")
Rel(dev, cpk, "HTTP to LoadBalancer IP", "kind subnet, host-routable")
Rel(api, ingress, "Schedules + tracks rollout")
Rel(cpk, cpk_sidecars, "Spawns one per LoadBalancer Service")
Rel(cpk_sidecars, apps, "Routes LB IP -> backend pods")
Rel(ingress, apps, "Routes by Host header")

' Opt-in Gateway API controllers: each provisions its own data plane whose
' type=LoadBalancer Service gets its own LB IP from cloud-provider-kind, all
' fronting the SAME demo apps by Host header. Enabled via make gateway-*.
Rel(cpk, gwistio, "Allocates LB IP per provisioned gateway Service")
Rel(cpk, gwngf, "Allocates LB IP per provisioned gateway Service")
Rel(cpk, gwcontour, "Allocates LB IP per provisioned gateway Service")
Rel(cpk, gwenvoy, "Allocates LB IP per provisioned gateway Service")
Rel(cpk, gwkgateway, "Allocates LB IP per provisioned gateway Service")
Rel(cpk, gwkong, "Allocates LB IP for the kong proxy Service")
Rel(cpk, inghaproxy, "Allocates LB IP for the HAProxy controller Service")
Rel(cpk, ingnginx, "Allocates LB IP for the NGINX Inc. controller Service")
Rel(inghaproxy, apps, "Routes by Host header (own LB IP)")
Rel(ingnginx, apps, "Routes by Host header (own LB IP)")
Rel(gwistio, apps, "Routes by Host header (own LB IP)")
Rel(gwngf, apps, "Routes by Host header (own LB IP)")
Rel(gwcontour, apps, "Routes by Host header (own LB IP)")
Rel(gwenvoy, apps, "Routes by Host header (own LB IP)")
Rel(gwkgateway, apps, "Routes by Host header (own LB IP)")
Rel(gwkong, apps, "Routes by Host header (own LB IP)")

Rel(prom, apps, "Scrapes /metrics", "HTTP")
Rel(apps, nfs, "Mounts RWX PVCs (optional)", "NFSv4")
Rel(api, charts, "helm install/upgrade pulls charts")
Rel(api, registries, "Pulls workload images")

SHOW_LEGEND()
@enduml
