@startuml c4-container
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.13.0/C4_Container.puml

' Modern flat styling: no shadows, sharper corners, clean sans-serif, modern palette.
skinparam backgroundColor #FAFAFA
skinparam shadowing false
skinparam roundCorner 4
skinparam defaultFontName "Inter, Helvetica, Arial, sans-serif"
skinparam defaultFontSize 13
skinparam ArrowColor #37474F
skinparam ArrowThickness 1.2
skinparam rectangleBorderThickness 1.3

UpdateElementStyle("person",       $fontColor="#FFFFFF", $bgColor="#0F766E", $borderColor="#134E4A")
UpdateElementStyle("container",    $fontColor="#FFFFFF", $bgColor="#2563EB", $borderColor="#1E3A8A")
UpdateElementStyle("container_db", $fontColor="#FFFFFF", $bgColor="#7C3AED", $borderColor="#4C1D95")
UpdateBoundaryStyle($bgColor="#F1F5F9", $borderColor="#94A3B8", $fontColor="#1E293B")

title Container View — kind-cluster

Person(dev, "Developer")

System_Boundary(host, "Host or Multipass VM") {
  Container(docker, "Docker Engine", "containerd", "Hosts KinD nodes")

  System_Boundary(kind, "KinD cluster") {
    Container(cp, "control-plane node", "kindest/node", "API server, scheduler, etcd, kubelet")
    Container(worker, "worker node", "kindest/node", "Pod runtime")

    Container(ingress, "Traefik", "Helm chart v3 (41.x)", "L7 routing; ingressClass traefik; pinned to control-plane via nodeSelector")
    Container(lb, "cloud-provider-kind", "docker container on kind network", "Allocates LoadBalancer IPs (primary; MetalLB alternative via LB=metallb)")
    Container(metrics, "metrics-server", "Helm chart 3.13.x", "Serves metrics.k8s.io for kubectl top / HPA")
    Container(dash, "Headlamp", "Helm chart 0.43.x", "ClusterIP :80; http://localhost:8081 via port-forward")
    ContainerDb(nfs, "NFS server + csi-driver-nfs", "in-cluster pod or host NFS", "ReadWriteMany PVCs")
    Container(prom, "kube-prometheus-stack", "Helm chart", "Prometheus + Grafana + Alertmanager")
    Container(apps, "Demo workloads", "httpd / hello-app / golang-web / http-echo", "Routed via ingress + LoadBalancer Services")

    System_Boundary(gwapi, "Gateway API controllers (opt-in)") {
      Container(gwcrds, "Gateway API CRDs", "experimental channel v1.6.0", "Shared GatewayClass/Gateway/HTTPRoute; one install for all controllers below")
      Container(gwistio, "Istio", "Helm base + istiod 1.30.2", "gatewayClassName: istio; auto-provisions Envoy gateway on its own LoadBalancer IP")
      Container(gwngf, "NGINX Gateway Fabric", "OCI Helm chart 2.6.6", "gatewayClassName: nginx; auto-provisions nginx data plane on its own LoadBalancer IP")
      Container(gwcontour, "Project Contour", "Gateway provisioner v1.33.5", "gatewayClassName: contour; provisions per-Gateway Envoy on its own LoadBalancer IP")
      Container(gwenvoy, "Envoy Gateway", "CNCF, Helm v1.8.2", "gatewayClassName: envoy; auto-provisions Envoy data plane on its own LoadBalancer IP")
      Container(gwkgateway, "kgateway", "CNCF (ex-Gloo), Helm v2.3.5", "gatewayClassName: kgateway; auto-provisions Envoy data plane on its own LoadBalancer IP")
      Container(gwkong, "Kong (KIC)", "umbrella chart 0.24.0, DB-less", "gatewayClassName: kong (unmanaged); binds to the single kong proxy LoadBalancer Service; also serves classic Ingress")
    }

    System_Boundary(ingalt, "Classic Ingress alternatives (opt-in)") {
      Container(inghaproxy, "HAProxy", "haproxytech chart 1.52.1", "ingressClassName: haproxy; own LoadBalancer IP, same demo apps")
      Container(ingnginx, "NGINX Inc.", "F5 OSS chart 2.6.1", "ingressClassName: nginx (distinct from NGF's GatewayClass); own LoadBalancer IP, same demo apps")
    }
  }
}

Rel(dev, docker, "docker / kind CLI")
Rel(dev, ingress, "HTTP via Host: demo.localdev.me", "127.0.0.1")
Rel(dev, lb, "HTTP to LoadBalancer IPs (host-routable via docker bridge)")
Rel(ingress, apps, "Routes /")
Rel(lb, apps, "Allocates LoadBalancer IP")

' Opt-in classic Ingress alternatives: distinct ingressClassName, each on its
' own LB IP, all fronting the SAME demo apps. Not part of `make install-all`.
Rel(inghaproxy, apps, "Routes by Host header (ingressClassName: haproxy, own LB IP)")
Rel(ingnginx, apps, "Routes by Host header (ingressClassName: nginx, own LB IP)")

' Opt-in Gateway API layer: Traefik also serves Gateway API from the same pod;
' Istio / NGF / Contour / Envoy Gateway / kgateway are additional controllers,
' each on its own LB IP, all fronting the SAME demo apps. Not part of `make install-all`.
Rel(ingress, gwcrds, "Also serves Gateway API (opt-in)", "*.gw.localdev.me")
Rel(gwistio, gwcrds, "Watches GatewayClass/HTTPRoute")
Rel(gwngf, gwcrds, "Watches GatewayClass/HTTPRoute")
Rel(gwcontour, gwcrds, "Watches GatewayClass/HTTPRoute")
Rel(gwenvoy, gwcrds, "Watches GatewayClass/HTTPRoute")
Rel(gwkgateway, gwcrds, "Watches GatewayClass/HTTPRoute")
Rel(gwkong, gwcrds, "Watches GatewayClass/HTTPRoute")
Rel(gwistio, apps, "Routes by Host header (own LB IP)")
Rel(gwngf, apps, "Routes by Host header (own LB IP)")
Rel(gwcontour, apps, "Routes by Host header (own LB IP)")
Rel(gwenvoy, apps, "Routes by Host header (own LB IP)")
Rel(gwkgateway, apps, "Routes by Host header (own LB IP)")
Rel(gwkong, apps, "Routes by Host header (own LB IP)")
Rel(apps, nfs, "Mounts RWX PVCs (optional)")
Rel(prom, apps, "Scrapes /metrics", "HTTP")
Rel(dev, prom, "Grafana UI", "kubectl port-forward")

Lay_D(docker, kind)
Lay_R(cp, worker)
Lay_D(ingress, apps)
Lay_R(lb, apps)

SHOW_LEGEND()
@enduml
